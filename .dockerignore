# ===========================================
# .dockerignore - Railway (nixpacks) এর জন্য
# এই ফাইলগুলো build context থেকে বাদ যাবে
# ===========================================

# --- Version Control ---
.git
.gitignore
.gitattributes

# --- Dependencies (fresh install হবে npm ci দিয়ে) ---
node_modules
**/node_modules

# --- Next.js build cache (production build নতুন হবে) ---
.next
out
build

# --- Bun (আপনি npm ব্যবহার করেন, bun লাগবে না) ---
bun.lock
bun.lockb
bunfig.toml
.bun

# --- Logs ---
*.log
dev.log
dev.out.log
server.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Development / Agent artifacts ---
tool-results
worklog.md
agent-ctx
.claude
.z-ai-config
.zscripts
local-*

# --- Skills (শুধু ডেভেলপমেন্টে দরকার, production এ না) ---
skills

# --- Mini services (যদি আলাদা deploy করেন) ---
mini-services

# --- Test / Coverage ---
test
coverage
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__

# --- Uploads (production এ নতুন আপলোড volume ব্যবহার করবেন) ---
upload
uploads

# --- SQLite DB files (prisma db push দিয়ে নতুন তৈরি হবে) ---
db/*.db
db/*.db-journal
prisma/db
*.db
*.db-journal

# --- Screenshots / Images (dev reference) ---
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.svg
!public/**
!src/**/*.svg

# --- Documentation ---
*.md
!node_modules/**/*.md
docs
README.md
CHANGELOG.md
LICENSE

# --- IDE / Editor ---
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Environment files (Railway নিজের env ব্যবহার করবে) ---
.env*
!.env.example

# --- Misc ---
.npm
.cache
tmp
temp
*.tar
*.zip
*.gz
