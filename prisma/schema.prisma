generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Channel {
  id           String   @id @default(cuid())
  name         String
  logo         String   @default("")
  category     String   @default("entertainment")
  streamType   String   @default("m3u")
  streamUrl    String   @default("")
  githubM3uPath String  @default("")
  language     String   @default("")
  country      String   @default("")
  tags         String   @default("")
  isFeatured   Boolean  @default(false)
  isActive     Boolean  @default(true)
  viewCount    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Match {
  id          String   @id @default(cuid())
  title       String
  sport       String   @default("football")
  teamA       String
  teamALogo   String   @default("")
  teamB       String
  teamBLogo   String   @default("")
  league      String   @default("")
  thumbnail   String   @default("")
  startTime   DateTime
  endTime     DateTime?
  status      String   @default("upcoming")
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  streams     MatchStream[]
}

model MatchStream {
  id         String @id @default(cuid())
  matchId    String
  name       String @default("Stream 1")
  channel    String @default("")
  type       String @default("iframe")
  url        String @default("")
  match      Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model Category {
  id           String   @id @default(cuid())
  name         String
  icon         String   @default("")
  color        String   @default("")
  order        Int      @default(0)
  channelCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AppSetting {
  id               String @id @default("app")
  appName          String @default("GenZ TV")
  logoUrl          String @default("")
  maintenanceMode  Boolean @default(false)
  featuredChannelId String @default("")
  heroBannerText   String @default("")
  defaultQuality   String @default("auto")
  bannerAdScript   String @default("")
  socialBarAdScript String @default("")
  customAdScripts  String @default("[]")  // JSON array of {id, name, script, position, enabled}
  adsEnabled       Boolean @default(true)
  homeAdsEnabled   Boolean @default(true)
  videoAdsEnabled  Boolean @default(true)
  apkUrl           String  @default("")
  // Phase 1: Analytics Setup — GA4
  ga4MeasurementId String @default("")  // e.g., G-XXXXXXXXXX
  // Phase 6: Firebase App Linking
  firebaseConfig   String @default("")  // JSON: Firebase web app config
}

model PushSubscription {
  id          String @id @default(cuid())
  endpoint    String @unique
  p256dh      String
  auth        String
  createdAt   DateTime @default(now())
}

// Analytics models
model PageView {
  id          String   @id @default(cuid())
  sessionId   String   // Browser fingerprint / session ID
  page        String   // Which page was viewed (home, watch, live, etc.)
  channelId   String?  // If watching a specific channel
  referrer    String   @default("")  // Where the visitor came from
  userAgent   String   @default("")
  country     String   @default("")
  ip          String   @default("")
  createdAt   DateTime @default(now())
}

model DailyStat {
  id           String   @id @default(cuid())
  date         String   @unique  // YYYY-MM-DD format
  totalViews   Int      @default(0)
  uniqueVisitors Int    @default(0)
  topPages     String   @default("{}")  // JSON: { page: count }
  topChannels  String   @default("{}")  // JSON: { channelId: count }
  topCountries String   @default("{}")  // JSON: { country: count }
  customEvents String   @default("{}")  // JSON: { eventName: count } — aggregated custom events per day
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VisitorSession {
  id          String   @id @default(cuid())
  sessionId   String   @unique  // Browser fingerprint
  firstSeen   DateTime @default(now())
  lastSeen    DateTime @default(now())
  pageCount   Int      @default(0)
  country     String   @default("")
  userAgent   String   @default("")
  ip          String   @default("")
  // Phase 4: User Properties
  deviceType  String   @default("")   // phone, tv, web
  region      String   @default("")   // from IP or browser
  connectionType String @default("")  // 4g, 3g, wifi, etc.
  appVersion  String   @default("")   // app version string
  notificationOptIn Boolean @default(false) // push notification opt-in
}

// Phase 3: Custom Event Tracking
model CustomEvent {
  id          String   @id @default(cuid())
  sessionId   String   // Browser session
  eventName   String   // e.g., match_card_click, stream_started
  params      String   @default("{}")  // JSON: event parameters
  page        String   @default("")    // Page where event occurred
  channelId   String?  // If related to a channel
  matchId     String?  // If related to a match
  userAgent   String   @default("")
  country     String   @default("")
  ip          String   @default("")
  createdAt   DateTime @default(now())
}

// Phase 5: Conversion Goals
model ConversionEvent {
  id          String   @id @default(cuid())
  sessionId   String   // Browser session
  goalName    String   // e.g., stream_started, rewarded_ad_complete, return_visit
  value       Float    @default(0)  // Conversion value (optional)
  params      String   @default("{}")  // JSON: additional parameters
  userAgent   String   @default("")
  country     String   @default("")
  ip          String   @default("")
  createdAt   DateTime @default(now())
}

// Match Chat
model ChatMessage {
  id          String   @id @default(cuid())
  matchId     String   // Which match this chat belongs to
  userId      String   // Persistent browser fingerprint
  username    String   // Display name (e.g., "Rony3847")
  message     String   // Chat message content
  type        String   @default("message")  // message, system, emoji
  replyToId   String?  // ID of message being replied to
  mentions    String   @default("[]")  // JSON: array of mentioned usernames
  createdAt   DateTime @default(now())
}
